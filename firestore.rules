rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is the owner
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Helper function to get band data from global collection
    function getGlobalBand(bandId) {
      return get(/databases/$(database)/documents/bands/$(bandId)).data;
    }

    // Helper function to check if user is a member of a global band
    // Uses memberUids array for efficient lookup (no map/filter available in rules)
    function isGlobalBandMember(bandId) {
      let band = getGlobalBand(bandId);
      return band != null &&
        band.memberUids.hasAny([request.auth.uid]);
    }

    // Helper function to check if user is an admin of a global band
    // Uses memberUids and adminUids arrays for efficient lookup
    // NOTE: Handles missing fields by checking if field exists
    function isGlobalBandAdmin(bandId) {
      let band = getGlobalBand(bandId);
      return band != null &&
        band.adminUids != null &&
        band.adminUids.hasAny([request.auth.uid]);
    }

    // Helper function to check if user is an editor or admin of a global band
    // Uses editorUids and adminUids arrays for efficient lookup
    // NOTE: Handles missing/null fields by checking existence first
    function isGlobalBandEditorOrAdmin(bandId) {
      let band = getGlobalBand(bandId);
      let isAdmin = band != null && band.adminUids != null && 
                    band.adminUids.hasAny([request.auth.uid]);
      let isEditor = band != null && band.editorUids != null && 
                     band.editorUids.hasAny([request.auth.uid]);
      return isAdmin || isEditor;
    }

    // Helper function to check if creating user is in members list
    function isCreatorInMembers(memberUids) {
      return memberUids.hasAny([request.auth.uid]);
    }

    // Helper function to check if user is adding themselves to members
    // Used for join band flow - user can add themselves but not modify others
    function isSelfJoinOnly(bandId) {
      let existingBand = getGlobalBand(bandId);
      let newMemberUids = request.resource.data.memberUids;
      // User can only join if:
      // 1. Band exists
      // 2. User is not already a member
      // 3. New members = existing members + current user
      return existingBand != null &&
        !existingBand.memberUids.hasAny([request.auth.uid]) &&
        newMemberUids.hasAll(existingBand.memberUids) &&
        newMemberUids.hasAll([request.auth.uid]) &&
        newMemberUids.size() == existingBand.memberUids.size() + 1;
    }

    // Helper function to validate band data on creation
    // Ensures required fields exist and have valid types
    function isValidBandData(data) {
      return data != null &&
        data.name != null && data.name is string && data.name.size() > 0 &&
        data.memberUids != null && data.memberUids is list && data.memberUids.size() > 0 &&
        data.adminUids != null && data.adminUids is list && data.adminUids.size() > 0 &&
        // Prevent injection: limit field sizes
        data.name.size() <= 100 &&
        (data.description == null || data.description is string && data.description.size() <= 500);
    }

    // Helper function to validate band updates
    // Prevents privilege escalation and ensures data integrity
    function isValidBandUpdate(oldData, newData) {
      // Admin cannot remove themselves (prevent lockout)
      let adminUidsRemoved = oldData.adminUids.diff(newData.adminUids);
      let isAdminRemovingSelf = adminUidsRemoved.hasAny([request.auth.uid]);
      
      // Member cannot remove themselves if they're the last admin
      let isLastAdmin = oldData.adminUids.size() == 1 && 
                        oldData.adminUids.hasAll([request.auth.uid]);
      
      return !isAdminRemovingSelf && 
        !isLastAdmin &&
        // Validate field sizes on update
        (newData.name == null || newData.name.size() <= 100) &&
        (newData.description == null || newData.description.size() <= 500);
    }

    // Helper function to validate song data on creation
    // Ensures required fields exist and have valid types
    function isValidSongData(data) {
      return data != null &&
        // Title is required and has reasonable length
        data.title != null && data.title is string && 
        data.title.size() > 0 && data.title.size() <= 200 &&
        // Artist is required and has reasonable length
        data.artist != null && data.artist is string &&
        data.artist.size() > 0 && data.artist.size() <= 200 &&
        // Optional fields with size limits
        (data.notes == null || data.notes is string && data.notes.size() <= 5000) &&
        (data.lyrics == null || data.lyrics is string && data.lyrics.size() <= 10000);
    }

    // Helper function to validate song updates
    // Prevents field size overflow
    function isValidSongUpdate(oldData, newData) {
      return (newData.title == null || newData.title.size() <= 200) &&
        (newData.artist == null || newData.artist.size() <= 200) &&
        (newData.notes == null || newData.notes.size() <= 5000) &&
        (newData.lyrics == null || newData.lyrics.size() <= 10000);
    }

    // ============================================================
    // Global Bands Collection
    // ============================================================
    // Stores all bands in a single collection for cross-user access
    match /bands/{bandId} {
      // Read: Only band members can read band data
      // This prevents unauthorized users from browsing all bands
      // Exception: Allow query by inviteCode for joining bands
      allow read: if isAuthenticated() && (
        isGlobalBandMember(bandId) ||
        // Allow reading band when querying by inviteCode (for join flow)
        // This is safe because inviteCode is a secret shared only with intended users
        (request.query.keys.hasAll(['inviteCode']) && 
         request.query.values.hasAny([resource.data.inviteCode]))
      );

      // Create: Any authenticated user can create a band (must be in members list)
      // Validation: Ensure required fields exist and memberUids is not empty
      allow create: if isAuthenticated() &&
        isCreatorInMembers(request.resource.data.memberUids) &&
        isValidBandData(request.resource.data);

      // Update: Only band admins can update band details
      // OR user can add themselves to members (join band flow)
      // Validation: Prevent privilege escalation
      allow update: if isAuthenticated() && (
        isGlobalBandAdmin(bandId) && isValidBandUpdate(resource.data, request.resource.data) ||
        isSelfJoinOnly(bandId)
      );

      // Delete: Only band admins can delete a band
      allow delete: if isAuthenticated() && isGlobalBandAdmin(bandId);
    }

    // ============================================================
    // Band Songs Subcollection
    // ============================================================
    // Songs stored under bands for collaborative band repertoire
    match /bands/{bandId}/songs/{songId} {
      // Band members can read
      allow read: if isAuthenticated() && isGlobalBandMember(bandId);

      // Band editors/admins can create
      // Validation: Ensure song data is valid
      allow create: if isAuthenticated() && 
        isGlobalBandEditorOrAdmin(bandId) &&
        isValidSongData(request.resource.data);

      // Band editors/admins can update
      // Validation: Prevent field size overflow
      allow update: if isAuthenticated() && 
        isGlobalBandEditorOrAdmin(bandId) &&
        isValidSongUpdate(resource.data, request.resource.data);

      // Band admins can delete
      allow delete: if isAuthenticated() && isGlobalBandAdmin(bandId);
    }

    // ============================================================
    // Users Collection - each user has their own subcollections
    // ============================================================
    match /users/{userId} {
      // Allow users to read/write their own user document
      allow read, write: if isAuthenticated() && isOwner(userId);

      // Songs subcollection - only owner can read/write
      match /songs/{songId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }

      // Bands subcollection - stores references to global bands
      // Band members can read, owner can write
      match /bands/{bandId} {
        allow read: if isAuthenticated() && (isOwner(userId) || isGlobalBandMember(bandId));
        allow write: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);

        // Band members subcollection (legacy, kept for compatibility)
        match /members/{memberId} {
          allow read: if isAuthenticated() && (isOwner(userId) || isGlobalBandMember(bandId));
          allow write: if isAuthenticated() && isOwner(userId);
        }
      }

      // Setlists subcollection - only owner can read/write
      match /setlists/{setlistId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }
    }
  }
}
