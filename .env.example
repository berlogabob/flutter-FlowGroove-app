# Firebase Configuration
# Get these from Firebase Console: https://console.firebase.google.com
# 1. Go to Project Settings
# 2. Scroll to "Your apps" section
# 3. Copy the configuration values
#
# SECURITY WARNING: Never commit .env file with real credentials!
# The .env file is in .gitignore - only commit this .env.example file.

FIREBASE_API_KEY=your_firebase_api_key_here

# Spotify API Credentials
# Get these from https://developer.spotify.com/dashboard
# 1. Go to https://developer.spotify.com/dashboard
# 2. Create an app to get Client ID and Client Secret
# 3. Copy this file to .env and replace the placeholder values
#
# SECURITY WARNING: Never commit .env file with real credentials!
# The .env file is in .gitignore - only commit this .env.example file.
#
# PRODUCTION RECOMMENDATION: Use SPOTIFY_PROXY_URL instead of direct credentials.
# See docs/SPOTIFY_PROXY_SETUP.md for backend proxy setup instructions.

# Direct API credentials (development only)
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Backend proxy URL (production recommended)
# When set, all Spotify API calls route through your secure backend
# SPOTIFY_PROXY_URL=https://your-backend.com/api/spotify

# Twitter/X API Credentials
# Get these from https://developer.twitter.com/en/portal/dashboard
# Create an app and enable OAuth 2.0
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here

# Track Analysis API (RapidAPI)
# Get free key: https://rapidapi.com/soundnet-soundnet-default/api/track-analysis
# Free tier: 100 requests/month
# Used for BPM and musical key analysis when Spotify is not available
TRACK_ANALYSIS_API_KEY=your_rapidapi_key_here
